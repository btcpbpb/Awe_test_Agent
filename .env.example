# ============================================================
# Awe_test_Agent 环境变量示例
# 使用方式：复制本文件为 .env
#   cp .env.example .env
# ============================================================

# ── AI 双模式（核心） ────────────────────────────────────────
# 编排层：谁负责写用例 / 修复 / 沉淀（默认 Cursor 智能体）
AI_ORCHESTRATOR=cursor
#   cursor  — Cursor IDE Task 子智能体 或 npm run agent（推荐）
#   manual  — 人工直接改代码，不走 Agent 流水线

# 运行时：测试执行中浏览器内的 AI 定位引擎
AI_RUNTIME=midscene
#   midscene    — Midscene 视觉定位（aiTap/aiInput，需下方 MIDSCENE_*）
#   playwright  — 纯 Playwright/CSS，不调用 Midscene

# ── Cursor 智能体（编排层，CLI 场景） ─────────────────────
# Cursor IDE 内对话无需 API Key；npm run agent 时需要：
# CURSOR_API_KEY=your-cursor-api-key
# CURSOR_AGENT_MODEL=composer-2.5

# ── Midscene 外部模型（运行时，AI_RUNTIME=midscene 时必填） ──
# 支持 OpenAI / DashScope / DeepSeek 等 OpenAI 兼容 API
MIDSCENE_MODEL_BASE_URL=https://api.openai.com/v1
MIDSCENE_MODEL_API_KEY=sk-your-api-key-here
MIDSCENE_MODEL_NAME=gpt-4o

# MIDSCENE_MODEL_FAMILY=qwen3.5
# MIDSCENE_MODEL_REASONING_ENABLED=false

# ── 项目与网站配置（可选） ────────────────────────────────────
# PROJECT=testerhome
# BASE_URL=https://testerhome.com
# LOGIN_URL=https://testerhome.com/account/sign_in

# ── 登录测试账号（可选） ────────────────────────────────────
# TEST_USERNAME=your_username_or_email
# TEST_PASSWORD=your_password

# ── 运行模式（可选） ────────────────────────────────────────
# HEADLESS=false
# DEBUG=false
